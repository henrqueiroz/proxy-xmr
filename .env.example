# Copie para .env (ou defina no EasyPanel em Environment).

# ---- GUI web ----
GUI_PORT=8080          # >>> PORTA DA GUI (acesse a interface por aqui) <<<
GUI_USER=admin         # usuário do login da GUI
GUI_PASS=troque-isto   # senha do login da GUI (TROQUE!)

# ---- API HTTP do xmrig-proxy (interna) ----
PROXY_API_PORT=8081
PROXY_API_TOKEN=troque-este-token

# ---- Comportamento ----
AUTO_START=true        # inicia o xmrig-proxy junto com o container
DATA_DIR=/data         # onde o config.json é persistido (monte um volume aqui)
